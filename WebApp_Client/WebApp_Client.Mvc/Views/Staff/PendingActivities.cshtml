@model IEnumerable<ActivityResponse>
@{
    ViewData["Title"] = "Pending Activities";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Approval queue</div>
        <h1 class="page-title">Pending Activities</h1>
        <p class="page-subtitle">Review organizer submissions and approve or reject activities waiting for staff decision.</p>
    </div>
</div>
<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>OrganizerName</th>
                <th>Location</th>
                <th>StartTime</th>
                <th>EndTime</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in Model)
            {
                <tr>
                    <td>@activity.Id</td>
                    <td>@activity.Title</td>
                    <td>@activity.OrganizerName</td>
                    <td>@activity.Location</td>
                    <td>@activity.StartTime.ToString("g")</td>
                    <td>@activity.EndTime.ToString("g")</td>
                    <td>@ActivityTypeName(activity.Type)</td>
                    <td><span class="badge bg-warning text-dark">@ActivityStatusName(activity.Status)</span></td>
                    <td class="d-flex flex-wrap gap-2">
                        <form asp-action="Approve" asp-route-id="@activity.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-success" type="submit">Approve</button>
                        </form>
                        <form asp-action="Reject" asp-route-id="@activity.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" type="submit">Reject</button>
                        </form>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="ActivityRegistrations" asp-action="Index" asp-route-activityId="@activity.Id" asp-route-returnUrl="@Url.Action("PendingActivities", "Staff")">View Registrations</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
