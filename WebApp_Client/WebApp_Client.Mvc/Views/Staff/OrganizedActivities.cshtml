@model IEnumerable<ActivityResponse>
@{
    ViewData["Title"] = "Approved Activities";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Staff audit</div>
        <h1 class="page-title">Approved Activities</h1>
        <p class="page-subtitle">
            These are activities that were approved and have already ended. Staff can review them and open registration lists, but attendance updates remain Organizer-only.
        </p>
    </div>
</div>
<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>OrganizerName</th>
                <th>Location</th>
                <th>StartTime</th>
                <th>EndTime</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in Model)
            {
                <tr>
                    <td>@activity.Id</td>
                    <td>@activity.Title</td>
                    <td>@activity.OrganizerName</td>
                    <td>@activity.Location</td>
                    <td>@activity.StartTime.ToString("g")</td>
                    <td>@activity.EndTime.ToString("g")</td>
                    <td>@ActivityTypeName(activity.Type)</td>
                    <td><span class="badge bg-secondary">@ActivityStatusName(activity.Status)</span></td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="ActivityRegistrations" asp-action="Index" asp-route-activityId="@activity.Id" asp-route-returnUrl="@Url.Action("ApprovedActivities", "Staff")">View Registrations</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
