@model ActivityRegistrationsViewModel
@{
    ViewData["Title"] = "Activity Registrations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a class="btn btn-outline-secondary mb-3" href="@Model.ReturnUrl">Back to Activity List</a>
        <h1 class="h3 mb-0">Activity Registrations</h1>
    </div>
    <div>
        @if (Model.CanManageAttendance)
        {
            <a class="btn btn-success" asp-action="Attendance" asp-route-activityId="@Model.ActivityId" asp-route-returnUrl="@Model.ReturnUrl">Attendance Management</a>
        }
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>RegistrationId</th>
                <th>ActivityTitle</th>
                <th>StudentName</th>
                <th>RegisteredAt</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var registration in Model.Registrations)
            {
                <tr>
                    <td>@registration.Id</td>
                    <td>@registration.ActivityTitle</td>
                    <td>@registration.StudentName</td>
                    <td>@registration.RegisteredAt.ToString("g")</td>
                    <td><span class="badge bg-secondary">@RegistrationStatusName(registration.Status)</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
