@model IEnumerable<ActivityResponse>
@{
    ViewData["Title"] = "Activities";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Public activities</div>
        <h1 class="page-title">Approved Activities</h1>
        <p class="page-subtitle">Browse activities that have been approved by staff.</p>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Location</th>
                <th>StartTime</th>
                <th>EndTime</th>
                <th>Type</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in Model)
            {
                <tr>
                    <td>@activity.Title</td>
                    <td>@activity.Location</td>
                    <td>@activity.StartTime.ToString("g")</td>
                    <td>@activity.EndTime.ToString("g")</td>
                    <td>@ActivityTypeName(activity.Type)</td>
                    <td><span class="badge bg-secondary">@ActivityStatusName(activity.Status)</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
