@model UpdateActivityRequest
@{
    ViewData["Title"] = "Edit Activity";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Update submission</div>
        <h1 class="page-title">Edit Activity</h1>
        <p class="page-subtitle">Update activity details. Backend rules decide whether this activity can still be edited.</p>
    </div>
</div>
<div class="card">
    <div class="card-body">
        @if (ViewBag.Error is string error)
        {
            <div class="alert alert-danger">@error</div>
        }
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <partial name="_ActivityForm" model="Model" />
            <div class="mt-4">
                <button class="btn btn-primary" type="submit">Save</button>
                <a class="btn btn-outline-secondary" asp-action="MyActivities">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
