@model IEnumerable<ActivityResponse>
@{
    ViewData["Title"] = "My Activities";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Organizer activity center</div>
        <h1 class="page-title">My Activities</h1>
        <p class="page-subtitle">Track approval status, edit eligible submissions, and open registrations or attendance for each activity.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Activity</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Location</th>
                <th>StartTime</th>
                <th>EndTime</th>
                <th>MaxParticipants</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in Model)
            {
                <tr>
                    <td>@activity.Id</td>
                    <td>@activity.Title</td>
                    <td>@activity.Location</td>
                    <td>@activity.StartTime.ToString("g")</td>
                    <td>@activity.EndTime.ToString("g")</td>
                    <td>@activity.MaxParticipants</td>
                    <td>@ActivityTypeName(activity.Type)</td>
                    <td><span class="badge bg-secondary">@ActivityStatusName(activity.Status)</span></td>
                    <td class="d-flex flex-wrap gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@activity.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="ActivityRegistrations" asp-action="Index" asp-route-activityId="@activity.Id" asp-route-returnUrl="@Url.Action("MyActivities", "Organizer")">View Registrations</a>
                        <a class="btn btn-sm btn-outline-success" asp-controller="ActivityRegistrations" asp-action="Attendance" asp-route-activityId="@activity.Id" asp-route-returnUrl="@Url.Action("MyActivities", "Organizer")">Attendance</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
