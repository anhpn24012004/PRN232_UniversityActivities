<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApp Client</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp_Client.Mvc.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">UA</span>
                    <span>University Activities</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            var roles = Context.Session.GetString(WebApp_Client.Mvc.SessionKeys.Roles) ?? string.Empty;
                            var isOrganizer = roles.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Contains("Organizer");
                            var isStaff = roles.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Contains("Staff");
                            var loggedIn = !string.IsNullOrWhiteSpace(Context.Session.GetString(WebApp_Client.Mvc.SessionKeys.Token));
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        @if (!loggedIn)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Activities">Activities</a></li>
                        }
                        @if (isOrganizer)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Organizer" asp-action="MyActivities">My Activities</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Organizer" asp-action="Create">Create Activity</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Profile">Profile</a></li>
                        }
                        @if (isStaff)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="PendingActivities">Pending</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="ApprovedActivities">Approved Activities</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="Registrations">Registrations</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Profile">Profile</a></li>
                        }
                    </ul>
                    @if (loggedIn)
                    {
                        <span class="user-chip me-3">@Context.Session.GetString(WebApp_Client.Mvc.SessionKeys.Email) <strong>@roles</strong></span>
                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger btn-sm" type="submit">Logout</button>
                        </form>
                    }
                    else
                    {
                        <span class="user-chip me-3">Guest</span>
                        <a class="btn btn-primary btn-sm me-2" asp-controller="Auth" asp-action="Login">Login</a>
                        <a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Register">Register</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="app-main">
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success">@success</div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger">@error</div>
            }
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
